{
  "name": "@estation/create-cms-site",
  "version": "1.2.2",
  "description": "MCP server to scaffold Next.js sites powered by eSTATION CMS",
  "type": "module",
  "bin": {
    "create-cms-site": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
